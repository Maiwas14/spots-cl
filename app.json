{
  "expo": {
    "name": "Spots",
    "slug": "spots-cl",
    "scheme": "spots",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3d2b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.spots.cl",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos tu ubicación para marcar dónde tomaste la foto.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para subirlas.",
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para tomar fotos de lugares.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.spots.cl",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDepB_2BmSENeQs4gwKbRz7z1pcFfqbh34"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#1a3d2b",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tus fotos para subir lugares.",
          "cameraPermission": "Necesitamos acceso a tu cámara para tomar fotos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7687acc7-5925-4f45-aed3-4fc088041468"
      }
    }
  }
}
